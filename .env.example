# spike-rak — Environment Variables
# Copy this file to .env and fill in the values
# Keys marked [optional] have fallbacks (mock/local) and can be left empty

# ── Phase 2: RAG Framework Comparison ────────────────────────────────────────

# OpenRouter API key — get one at https://openrouter.ai  [optional → mock response]
OPENROUTER_API_KEY=sk-or-...

# LLM model to use via OpenRouter
# Examples: openai/gpt-4o-mini, anthropic/claude-3-haiku, google/gemini-flash-1.5
RAG_LLM_MODEL=openai/gpt-4o-mini

# Embedding model (sentence-transformers, runs locally — no API key needed)
# Fast (English):            all-MiniLM-L6-v2              (~80MB)
# Multilingual Thai+English: intfloat/multilingual-e5-small (~470MB)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# ── Phase 3: Embedding Models ─────────────────────────────────────────────────

# [optional] required only for OpenAI embedding models (openai_large / openai_small)
OPENAI_API_KEY=sk-...

# ── Phase 3.5: LLM Providers ─────────────────────────────────────────────────

# [optional] for direct Anthropic API comparison (non-OpenRouter)
ANTHROPIC_API_KEY=sk-ant-...

# ── Phase 4 & 5: API Server ───────────────────────────────────────────────────

# JWT signing key — change this in any non-local environment
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# [optional] same key as above — enables real LLM in API
# Without this, API returns mock responses (fine for Phase 5 tests)
# OPENROUTER_API_KEY already set above

# OpenRouter model for API
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Phase 4: LINE Messaging API (optional) ────────────────────────────────────
# Required only for real LINE webhook integration
# Without these, signature check is skipped in dev mode
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
