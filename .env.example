# ── Phase 2: RAG Framework Comparison ────────────────────────────────────────
# Copy this file to .env and fill in the values

# OpenRouter API key — get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# LLM model to use via OpenRouter
# Examples: anthropic/claude-3-haiku, openai/gpt-4o-mini, google/gemini-flash-1.5
RAG_LLM_MODEL=anthropic/claude-3-haiku

# Embedding model (sentence-transformers, runs locally — no API key needed)
# Fast (English-focused):      all-MiniLM-L6-v2         (~80MB)
# Multilingual Thai+English:   intfloat/multilingual-e5-small  (~470MB)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# Retrieval top-k
RAG_TOP_K=3
